<?xml version="1.0" encoding="utf-8"?>
<!--
    Pre-Android 12 backup rules (Google Drive auto-backup).
    Keep this for backward compat with API < 31.
-->
<full-backup-content>
    <include domain="sharedpref" path="." />
    <exclude domain="database" path="." />
    <exclude domain="file" path="WebKit" />
    <exclude domain="file" path="ionic_built_snapshots" />
    <exclude domain="external" path="." />
    <exclude domain="root" path="." />
</full-backup-content>
