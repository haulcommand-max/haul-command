<?xml version="1.0" encoding="utf-8"?>
<!--
    Network Security Configuration for Haul Command.
    - Production: HTTPS only (cleartext blocked)
    - Debug builds: allow cleartext to localhost for Capacitor dev server
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Dev server: allow cleartext to localhost only in debug builds -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="user" />
            <certificates src="system" />
        </trust-anchors>
    </debug-overrides>

    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>
</network-security-config>
