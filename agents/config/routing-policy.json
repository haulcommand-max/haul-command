{
  "version": "1.0.0",
  "description": "Haul Command Model Routing Policy — auto-selects cheapest model per task",
  "updated": "2026-04-12",

  "cost_ladder": [
    "no-model (process/http)",
    "gpt-5.4-nano / gemini-2.5-flash-lite",
    "gpt-5.4-mini / gemini-2.5-flash",
    "gpt-5.4 / claude-sonnet-4.6",
    "claude-opus-4.6 / gemini-2.5-pro"
  ],

  "providers": {
    "anthropic": {
      "models": {
        "claude-opus-4.6":   { "input_per_mtok": 5.00,  "output_per_mtok": 25.00, "context_window": 1000000, "tier": "executive" },
        "claude-sonnet-4.6": { "input_per_mtok": 3.00,  "output_per_mtok": 15.00, "context_window": 1000000, "tier": "senior" },
        "claude-haiku-4.5":  { "input_per_mtok": 1.00,  "output_per_mtok": 5.00,  "context_window": 200000,  "tier": "junior" }
      },
      "env_key": "ANTHROPIC_API_KEY"
    },
    "openai": {
      "models": {
        "gpt-5.4":      { "input_per_mtok": 2.50,  "output_per_mtok": 15.00, "context_window": 1050000, "tier": "senior" },
        "gpt-5.4-mini": { "input_per_mtok": 0.75,  "output_per_mtok": 4.50,  "context_window": 1050000, "tier": "junior" },
        "gpt-5.4-nano": { "input_per_mtok": 0.20,  "output_per_mtok": 1.25,  "context_window": 1050000, "tier": "grunt" }
      },
      "env_key": "OPENAI_API_KEY"
    },
    "google": {
      "models": {
        "gemini-2.5-pro":        { "input_per_mtok": 1.25,  "output_per_mtok": 5.00,  "context_window": 1000000, "tier": "senior" },
        "gemini-2.5-flash":      { "input_per_mtok": 0.30,  "output_per_mtok": 2.50,  "context_window": 1000000, "tier": "junior" },
        "gemini-2.5-flash-lite": { "input_per_mtok": 0.10,  "output_per_mtok": 0.40,  "context_window": 1000000, "tier": "grunt" }
      },
      "env_key": "GOOGLE_API_KEY"
    }
  },

  "routing_rules": {
    "step_1_no_model": {
      "description": "If the task is deterministic, skip the LLM entirely",
      "conditions": [
        "Database read/write (Supabase RPC, insert, update)",
        "API polling (DAT, Truckstop, FMCSA SAFER, NOAA, Mapbox)",
        "Scheduled cron trigger",
        "Fixed-rules engine (permit filing, A/R aging thresholds)",
        "Data transform / ETL (CSV parse, JSON reshape)",
        "Webhook fire (IndexNow, email send via SendGrid/Resend)",
        "Scraping with known selectors",
        "Template-based email generation (merge fields only)"
      ],
      "route_to": "process/http (no model)"
    },

    "step_2_classify": {
      "fields": {
        "blast_radius":    { "type": "enum", "values": ["low", "medium", "high", "critical"], "description": "What breaks if the answer is wrong?" },
        "latency_ms":      { "type": "number", "description": "Max acceptable response time" },
        "context_tokens":  { "type": "number", "description": "Input + expected output tokens" },
        "modality":        { "type": "enum", "values": ["text", "code", "vision", "voice"], "description": "What kind of I/O?" },
        "cost_ceiling":    { "type": "number", "description": "Max $ per invocation" }
      }
    },

    "step_3_default_tier": [
      {
        "condition": "blast_radius == critical OR trust_risk == true OR touches payments/auth/RLS",
        "model": "claude-opus-4.6",
        "rationale": "Board-grade judgment. Irreversible decisions. Public compliance claims."
      },
      {
        "condition": "modality == code AND blast_radius >= medium",
        "model": "gpt-5.4",
        "rationale": "Default coding model. Schema migrations, debugging, integration planning."
      },
      {
        "condition": "modality == code AND blast_radius == low",
        "model": "gpt-5.4-mini",
        "rationale": "Coding subagents. Template generation. Test writing. Boilerplate."
      },
      {
        "condition": "context_tokens > 200000",
        "model": "gemini-2.5-pro",
        "rationale": "Giant-context sweeps. Full-codebase audits. Long research. Multi-file diff review."
      },
      {
        "condition": "blast_radius == medium AND modality == text",
        "model": "gemini-2.5-flash",
        "rationale": "Smart reasoning at volume. Operational decisions. Content quality checks."
      },
      {
        "condition": "blast_radius <= medium AND trust_risk == false AND modality == text",
        "model": "claude-sonnet-4.6",
        "rationale": "Second-tier hard reasoning. Trust/compliance review when Opus not needed."
      },
      {
        "condition": "bulk_classification OR tag_extraction OR simple_rewrite",
        "model": "gemini-2.5-flash-lite",
        "rationale": "Ultra-cheap. Tagging, enrichment, drafting, data cleanup."
      },
      {
        "condition": "tiny_label OR routing_decision OR format_conversion",
        "model": "gpt-5.4-nano",
        "rationale": "Cheapest text model. Classification, rewrites, routing labels."
      }
    ],

    "step_4_escalation": {
      "triggers": [
        "Model returns confidence < 0.7",
        "Model hits context limit",
        "Task fails twice on current tier",
        "Task touches payments, trust, compliance, or public claims",
        "Human-flagged for review"
      ],
      "escalation_chain": [
        "gpt-5.4-nano → gpt-5.4-mini",
        "gemini-2.5-flash-lite → gemini-2.5-flash",
        "gpt-5.4-mini → gpt-5.4",
        "gemini-2.5-flash → gemini-2.5-pro",
        "gpt-5.4 → claude-sonnet-4.6",
        "claude-sonnet-4.6 → claude-opus-4.6"
      ]
    }
  },

  "agent_assignments": {
