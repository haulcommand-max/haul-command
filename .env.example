# ─────────────────────────────────────────────────────────────────────────────
# Haul Command — Environment Variable Contract
# Copy to .env.local and populate. On Vercel: Project Settings → Environment Variables.
#
# Legend:   REQUIRED = must be set    OPTIONAL = graceful degradation    SCAFFOLD = disabled by default
# Updated: 2026-03-13 — full stack reconciliation pass
# ─────────────────────────────────────────────────────────────────────────────

# ═══════════════════════════════════════════════════════════════════════════════
# CORE SERVICES (always on — no feature flag)
# ═══════════════════════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co            # REQUIRED
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...                                     # REQUIRED
SUPABASE_URL=https://your-project-ref.supabase.co                        # REQUIRED (server alias)
SUPABASE_SERVICE_ROLE_KEY=eyJ...                                         # REQUIRED (server only)

# ── Firebase (Push + Analytics) ───────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=                                            # REQUIRED
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=haul-command.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=haul-command
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=haul-command.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=                                             # REQUIRED (web app ID)
NEXT_PUBLIC_FIREBASE_VAPID_KEY=                                          # REQUIRED for push
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=                                     # OPTIONAL (GA4 via Firebase)

# ── Application ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://haulcommand.com
NEXT_PUBLIC_APP_URL=https://haulcommand.com
CRON_SECRET=                                                             # REQUIRED (openssl rand -hex 32)
HC_ADMIN_SECRET=                                                         # REQUIRED (openssl rand -hex 32)

# ═══════════════════════════════════════════════════════════════════════════════
# ACTIVE INTEGRATIONS (feature-flagged — set FEATURE_<NAME>=true to enable)
# ═══════════════════════════════════════════════════════════════════════════════

# ── HERE Maps (routing, geocoding, distance) ──────────────────────────────────
FEATURE_HERE_MAPS=true
HERE_API_KEY=                                                            # Get: https://platform.here.com → API Keys
NEXT_PUBLIC_HERE_API_KEY=                                                # Browser map rendering (can = HERE_API_KEY)

# ── Overpass / OSM (infrastructure harvesting) ────────────────────────────────
FEATURE_OVERPASS_OSM=true
OVERPASS_API_URL=https://overpass-api.de/api/interpreter                 # Default public instance

# ── Traccar (GPS telematics, tracking, geofences) ─────────────────────────────
FEATURE_TRACCAR=true
TRACCAR_API_URL=                                                         # e.g., https://your-traccar.fly.dev/api
TRACCAR_API_TOKEN=                                                       # Get: Traccar → Settings → API Token
TRACCAR_USER=                                                            # Alt: basic auth user
TRACCAR_PASS=                                                            # Alt: basic auth password

# ── Langfuse (LLM observability, prompt tracing) ─────────────────────────────
FEATURE_LANGFUSE=true
LANGFUSE_SECRET_KEY=                                                     # Get: https://cloud.langfuse.com → API Keys
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ── Trigger.dev (background job orchestration) ────────────────────────────────
FEATURE_TRIGGER_DEV=true
TRIGGER_API_KEY=                                                         # Get: https://cloud.trigger.dev → API Keys
TRIGGER_API_URL=https://api.trigger.dev

# ── Infisical (secrets management) ────────────────────────────────────────────
FEATURE_INFISICAL=false                                                  # Opt-in — falls back to process.env
INFISICAL_TOKEN=                                                         # Get: https://app.infisical.com → Service Tokens
INFISICAL_API_URL=https://app.infisical.com/api

# ── Dub.co (short links, QR, attribution) ─────────────────────────────────────
FEATURE_DUB=true
DUB_API_KEY=                                                             # Get: https://app.dub.co → API Keys
DUB_WORKSPACE_SLUG=haulcommand

# ── Twenty CRM (ops / relationship spine) ─────────────────────────────────────
FEATURE_TWENTY_CRM=true
TWENTY_API_URL=                                                          # e.g., https://your-twenty.fly.dev/api
TWENTY_API_KEY=

# ── Listmonk (email campaigns, newsletters) ──────────────────────────────────
FEATURE_LISTMONK=true
LISTMONK_URL=                                                            # e.g., https://your-listmonk.fly.dev
LISTMONK_API_USER=admin
LISTMONK_API_PASSWORD=

# ── Vapi (AI voice agents, call workflows) ────────────────────────────────────
FEATURE_VAPI=true
VAPI_PRIVATE_API_KEY=                                                    # Get: https://vapi.ai → Dashboard → API Keys

# ── Fly.io (workers, agents, background compute) ─────────────────────────────
FEATURE_FLY_IO=false                                                     # Enable after fly deploy
FLY_API_TOKEN=                                                           # Get: fly auth token
FLY_WORKER_URL=                                                          # e.g., https://hc-workers.fly.dev

# ── Tolgee (localization / i18n — 57-country expansion) ───────────────────────
FEATURE_TOLGEE=true
TOLGEE_API_KEY=                                                          # Get: https://app.tolgee.io → API Keys
TOLGEE_API_URL=https://app.tolgee.io
TOLGEE_PROJECT_ID=

# ── Telnyx (local phone numbers, SMS, voice routing) ──────────────────────────
FEATURE_TELNYX=true
TELNYX_API_KEY=                                                          # Get: https://portal.telnyx.com → API Keys
TELNYX_MESSAGING_PROFILE_ID=

# ═══════════════════════════════════════════════════════════════════════════════
# SCAFFOLD — DISABLED BY DEFAULT (set FEATURE_<NAME>=true to activate)
# ═══════════════════════════════════════════════════════════════════════════════

# ── Documenso (digital signatures) ────────────────────────────────────────────
FEATURE_DOCUMENSO=false
DOCUMENSO_API_KEY=                                                       # Get: https://app.documenso.com → API Keys
DOCUMENSO_API_URL=https://app.documenso.com/api/v1

# ── Lago (usage-based billing) ────────────────────────────────────────────────
FEATURE_LAGO=false
LAGO_API_KEY=
LAGO_API_URL=https://api.getlago.com/api/v1

# ═══════════════════════════════════════════════════════════════════════════════
# ANALYTICS & MONITORING
# ═══════════════════════════════════════════════════════════════════════════════

FEATURE_POSTHOG=true
NEXT_PUBLIC_POSTHOG_KEY=                                                 # Get: https://posthog.com → Project → API Key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

FEATURE_SENTRY=true
SENTRY_DSN=                                                              # Get: https://sentry.io → Project → DSN

FEATURE_GOOGLE_ANALYTICS=false
NEXT_PUBLIC_GA_ID=                                                       # Get: https://analytics.google.com → Measurement ID

# ═══════════════════════════════════════════════════════════════════════════════
# PAYMENTS
# ═══════════════════════════════════════════════════════════════════════════════

FEATURE_STRIPE=true
STRIPE_SECRET_KEY=sk_test_...                                            # Get: https://dashboard.stripe.com → API Keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# HC Certified Training — create one-time prices in Stripe Dashboard for each
STRIPE_PRICE_HC_CERTIFIED=price_...                                      # $49 one-time or bundled with Pro
STRIPE_PRICE_AV_READY=price_...                                          # $149/year subscription
STRIPE_PRICE_HC_ELITE=price_...                                          # $299/year subscription

FEATURE_NOWPAYMENTS=true
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_AFFILIATE_ID=

# ═══════════════════════════════════════════════════════════════════════════════
# COMMS & NOTIFICATIONS
# ═══════════════════════════════════════════════════════════════════════════════

FEATURE_LIVEKIT=false
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
NEXT_PUBLIC_LIVEKIT_WS_URL=

FEATURE_NOVU=false
NOVU_API_KEY=

FEATURE_RESEND=false
RESEND_API_KEY=
EMAIL_FROM=no-reply@haulcommand.com

FEATURE_BREVO_SMTP=false
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ═══════════════════════════════════════════════════════════════════════════════
# AI
# ═══════════════════════════════════════════════════════════════════════════════

GEMINI_API_KEY=                                                          # REQUIRED for AI Image Engine
OPENAI_API_KEY=                                                          # REQUIRED for AI agents

# ═══════════════════════════════════════════════════════════════════════════════
# MAP TILES
# ═══════════════════════════════════════════════════════════════════════════════

NEXT_PUBLIC_MAPLIBRE_STYLE=https://basemaps.cartocdn.com/gl/dark-matter-gl-style/style.json

# ═══════════════════════════════════════════════════════════════════════════════
# REMOVED SERVICES (do not add back without architecture review)
# ═══════════════════════════════════════════════════════════════════════════════
# Pinecone — removed (Supabase FTS + Typesense cover search)
# Netlify — removed (Vercel is the deployment platform)
# Notion — removed (no code usage)
# Stitch — removed (no code usage)
# MCP Toolbox for Databases — removed (Supabase MCP covers this)
# Navixy — replaced by Traccar (see lib/telematics/traccar.ts)
# GoHighLevel — removed (replaced by Twenty CRM)
# Google AdSense — removed (not needed at this stage)
# Google reCAPTCHA — removed (not implemented)
# mapbox-gl — removed (maplibre-gl is the map renderer)
# workbox-* — removed (no code usage)
# @supabase/auth-helpers-nextjs — removed (replaced by @supabase/ssr)

# ─────────────────────────────────────────────────────────────────────────────
# VERCEL DEPLOYMENT CHECKLIST
# ─────────────────────────────────────────────────────────────────────────────
# 1. Import repo at vercel.com/new
# 2. Framework preset: Next.js (auto-detected)
# 3. Add the REQUIRED env vars above in Vercel dashboard
# 4. Add FEATURE_* flags for integrations you want active
# 5. Click Deploy
# ─────────────────────────────────────────────────────────────────────────────
