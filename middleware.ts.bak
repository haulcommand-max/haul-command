import { NextResponse } from 'next/server';
import type { NextRequest } from 'next/server';

/**
 * Haul Command — Routing Authority Lock (Phase 1)
 *
 * Enforces canonical URL patterns.
 * Legacy nested routes are 301 permanently redirected to the new flat/determinstic hubs.
 */

export function middleware(request: NextRequest) {
    const url = request.nextUrl.clone();
    const { pathname, pathname: path } = url;

    // ─────────────────────────────────────────────────────────────
    // REDIRECT MATRIX (LEGACY → CANONICAL)
    // ─────────────────────────────────────────────────────────────

    // 1) Legacy: /directory/[country] → /[country]
    // Example: /directory/us → /us
    const directoryCountryMatch = path.match(/^\/directory\/([a-zA-Z]{2})$/i);
    if (directoryCountryMatch) {
        url.pathname = `/${directoryCountryMatch[1].toLowerCase()}`;
        return NextResponse.redirect(url, 301);
    }

    // 2) Legacy: /[country]/places → /[country]
    // Example: /us/places → /us
    const countryPlacesMatch = path.match(/^\/([a-zA-Z]{2})\/places$/i);
    if (countryPlacesMatch) {
        url.pathname = `/${countryPlacesMatch[1].toLowerCase()}`;
        return NextResponse.redirect(url, 301);
    }

    // 3) Legacy: /pilot-car/[state] → /{country}/{state}/pilot-car-services
    // Example: /pilot-car/texas → /us/texas/pilot-car-services
    const pilotCarStateMatch = path.match(/^\/pilot-car\/([a-zA-Z0-9-]+)$/i);
    if (pilotCarStateMatch) {
        const stateSlug = pilotCarStateMatch[1].toLowerCase();
        // Fallback country to US in this generic catch (can be enhanced if CA provinces)
        const isCanada = ['alberta', 'bc', 'ontario', 'quebec', 'saskatchewan'].includes(stateSlug);
        const country = isCanada ? 'ca' : 'us';
        url.pathname = `/${country}/${stateSlug}/pilot-car-services`;
        return NextResponse.redirect(url, 301);
    }

    // 4) Legacy: /corridors/[route] → /corridor/[route]
    const corridorsPluralMatch = path.match(/^\/corridors\/(.*)$/i);
    if (corridorsPluralMatch) {
        url.pathname = `/corridor/${corridorsPluralMatch[1].toLowerCase()}`;
        return NextResponse.redirect(url, 301);
    }

    // 5) Legacy: /high-pole-escorts/[city] → /high-pole-escort-{city}-near-me
    const highPoleMatch = path.match(/^\/high-pole-escorts\/([a-zA-Z0-9-]+)$/i);
    if (highPoleMatch) {
        url.pathname = `/high-pole-escort-${highPoleMatch[1].toLowerCase()}-near-me`;
        return NextResponse.redirect(url, 301);
    }

    // Enforce lowercase paths to prevent duplicate content indexing
    if (path !== path.toLowerCase() && !path.includes('_next') && !path.match(/\.(png|jpg|jpeg|svg|ico|avif|webp|json|xml)$/)) {
        url.pathname = path.toLowerCase();
        return NextResponse.redirect(url, 301);
    }

    // Continue if no redirects triggered
    return NextResponse.next();
}

export const config = {
    // Avoid running middleware on static files and Next.js internal paths
    matcher: [
        '/((?!_next/static|_next/image|favicon.ico|brand|.*\\.(?:svg|png|jpg|jpeg|gif|webp|avif)$).*)',
    ],
};
