<?xml version="1.0" encoding="utf-8"?>
<!--
    Android 12+ data extraction rules (device-to-device transfer).
    Controls what data is migrated when a user sets up a new device.
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Include user preferences -->
        <include domain="sharedpref" path="." />
        <!-- Exclude auth tokens, session data, and Capacitor internals -->
        <exclude domain="database" path="." />
        <exclude domain="file" path="ionic_built_snapshots" />
        <exclude domain="file" path="WebKit" />
        <exclude domain="external" path="." />
    </cloud-backup>
    <device-transfer>
        <!-- Allow broader transfer when moving between devices -->
        <include domain="sharedpref" path="." />
        <include domain="file" path="." />
        <exclude domain="file" path="WebKit" />
        <exclude domain="database" path="." />
        <exclude domain="external" path="." />
    </device-transfer>
</data-extraction-rules>
