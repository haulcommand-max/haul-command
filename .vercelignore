# Vercel Ignore — exclude non-app subdirectories from deployment bundle.
# These directories contain their own package.json/lockfiles that confuse
# Vercel's workspace root detection, causing API routes to be dropped.
#
# IMPORTANT: Use leading slash (/) to anchor patterns to the REPO ROOT only.
# NOTE: Do NOT exclude /scripts/ — it contains postinstall-patch.mjs needed by build.

/command-dashboard/
/haul-command-hub/
/source_data/
/workers/
/docs/
/lighthouse/
/tmp/
