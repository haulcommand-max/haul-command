{
    "name": "haul-command-bots",
    "version": "1.0.0",
    "description": "Automation bots for Haul Command",
    "main": "index.js",
    "scripts": {
        "postinstall": "node scripts/postinstall-patch.mjs",
        "dev": "next dev",
        "build": "node scripts/postinstall-patch.mjs && next build",
        "start": "next start",
        "lint": "next lint",
        "typecheck": "tsc --noEmit",
        "brand:generate": "node scripts/brand/generate-assets.mjs",
        "brand:verify": "node scripts/brand/verify-assets.mjs",
        "brand:build": "npm run brand:generate && npm run brand:verify",
        "brand:legacy": "node scripts/brand/generate-icons.mjs",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "test:e2e": "npx playwright test",
        "test:e2e:ui": "npx playwright test --ui",
        "build:mobile": "npx cap sync",
        "build:android": "npx cap sync android && npx cap open android",
        "build:ios": "npx cap sync ios && npx cap open ios",
        "clean:all": "rm -rf .next node_modules/.cache dist-capacitor android/app/build android/.gradle && echo 'Cleaned all build caches'",
        "doctor": "node scripts/doctor.mjs",
        "verify": "node scripts/verify-no-regressions.mjs",
        "brand:facebook": "node scripts/brand/facebook-cover.mjs",
        "test:visual": "npx playwright test tests/e2e/visual-regression.spec.ts",
        "test:visual:update": "npx playwright test tests/e2e/visual-regression.spec.ts --update-snapshots",
        "ingest:scrape": "node scripts/seed/scrape-all-states.mjs",
        "ingest:expand": "node scripts/seed/crawl-outbound-sites.mjs",
        "ingest:seed": "node scripts/seed/load-seed-to-supabase.mjs",
        "ingest:pipeline": "node scripts/seed/run-full-pipeline.mjs",
        "migrate": "node scripts/migrate.mjs"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
