# Haul Command — Stripe Setup Runbook
# Run after migration 015 is applied in Supabase

# Step 1: Create all products in Stripe Dashboard OR via CLI:
#   stripe products create --name="Corridor Intelligence Starter" ...
# Then copy the price IDs into .env.local

# Step 2: Set these env vars (add to Vercel + .env.local)

# Data Products
STRIPE_PRODUCT_CORRIDOR_STARTER=prod_xxx
STRIPE_PRICE_CORRIDOR_STARTER=price_xxx

STRIPE_PRODUCT_CORRIDOR_PRO=prod_xxx
STRIPE_PRICE_CORRIDOR_PRO=price_xxx

# AdGrid — Corridor
STRIPE_ADGRID_CORRIDOR_30D=price_xxx
STRIPE_ADGRID_CORRIDOR_90D=price_xxx
STRIPE_ADGRID_CORRIDOR_180D=price_xxx

# AdGrid — Country
STRIPE_ADGRID_COUNTRY_30D=price_xxx
STRIPE_ADGRID_COUNTRY_90D=price_xxx

# AdGrid — Leaderboard
STRIPE_ADGRID_LEADERBOARD_30D=price_xxx
STRIPE_ADGRID_LEADERBOARD_90D=price_xxx

# AdGrid — Tool / Glossary / Data
STRIPE_ADGRID_TOOL_30D=price_xxx
STRIPE_ADGRID_GLOSSARY_30D=price_xxx
STRIPE_ADGRID_DATA_PRODUCT_30D=price_xxx

# Step 3: Wire Stripe webhook for slot activation
# Endpoint: POST /api/webhooks/stripe
# Events: checkout.session.completed, payment_intent.succeeded

# Step 4: Update hc_stripe_products table with real IDs:
# UPDATE public.hc_stripe_products
#   SET stripe_product_id = 'prod_xxx', stripe_price_id = 'price_xxx'
#   WHERE product_key = 'corridor-starter';
